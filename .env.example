# Database Configuration
DB_PASSWORD=your_secure_db_password_here

# Security Configuration
SECRET_KEY=your_256_bit_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External API Keys
GSTN_API_URL=https://api.gst.gov.in
GSTN_CLIENT_ID=your_gstn_client_id
GSTN_CLIENT_SECRET=your_gstn_client_secret
RBI_FX_API_KEY=your_rbi_fx_api_key

# Quantum Engine
QUANTUM_ENGINE_URL=http://quantum-engine:8080

# Monitoring and Alerting
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_secure_grafana_password

# Email Configuration for Alerts
SMTP_USERNAME=spoorthy306@gmail.com
SMTP_PASSWORD=your_smtp_app_password
CRITICAL_ALERT_EMAIL=spoorthy306@gmail.com
WARNING_ALERT_EMAIL=spoorthy306@gmail.com
TEAM_ALERT_EMAIL=spoorthy306@gmail.com

# Slack Integration (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=csv,xlsx,pdf,jpg,jpeg,png

# Quantum Engine Configuration
QUANTUM_SIMULATION_MODE=true
MAX_QUBITS=512
QUANTUM_TIMEOUT_SECONDS=300

# Compliance Configuration
GST_FILING_DEADLINE_DAYS=20
TAX_RETURN_DEADLINE_DAYS=31
AUDIT_RETENTION_YEARS=8

# Performance Configuration
API_RATE_LIMIT_REQUESTS=1000
API_RATE_LIMIT_WINDOW=3600  # 1 hour in seconds
CACHE_TTL_SECONDS=3600

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Security Headers
CORS_ORIGINS=http://localhost:3000,https://spoorthy-erp.com
SECURE_COOKIES=true
SESSION_TIMEOUT_MINUTES=480  # 8 hours

# Feature Flags
ENABLE_QUANTUM_OPTIMIZATION=true
ENABLE_AI_INSIGHTS=true
ENABLE_AUTO_RECONCILIATION=true
ENABLE_REAL_TIME_DASHBOARD=true

# Development/Production Mode
ENVIRONMENT=production
DEBUG=false
