# Gmail SMTP credentials for send_email()
# Copy this file to .env and fill in your values.
# SMTP_PASS must be a Gmail App Password (16 chars, no spaces).
# Generate one at: Google Account → Security → App passwords
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Database (leave blank to use SQLite default)
# SPOORTHY_DB_URL=postgresql://user:pass@localhost/spoorthy_erp
