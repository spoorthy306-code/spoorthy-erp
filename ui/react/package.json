{
  "name": "spoorthy-erp-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build && node ./scripts/build-size.mjs",
    "build:check": "npm run build && npm run check:bundle",
    "build:size": "node ./scripts/build-size.mjs",
    "check:bundle": "node ./scripts/check-bundle-size.mjs",
    "serve": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "audit:components": "node scripts/check-missing-components.mjs",
    "audit:bugs": "node scripts/detect-bugs.mjs",
    "audit:report": "node scripts/generate-audit-report.mjs",
    "audit:full": "npm run type-check && npm run lint && npm run test -- --run && npm run build && npm run audit:components && npm run audit:bugs && npm run audit:report",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:info": "tauri info",
    "desktop:parity": "node scripts/check-desktop-parity.mjs",
    "desktop:validate": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-desktop.ps1"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.59.16",
    "@tauri-apps/api": "^2.10.1",
    "axios": "^1.7.7",
    "framer-motion": "^11.11.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-router-dom": "^6.28.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
